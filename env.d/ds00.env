# ds00.env — Machine-level config for DS00
# Dual Intel Xeon Gold 6430 (32 physical cores/socket), 128GB, HT off.
#
# The DGC dependency tree (prebuilt JDK, SPECjbb, HBase, DaCapo) lives as
# siblings of the artifact root and is picked up via the env.sh defaults.
# Only the network address differs from ds03.

DGC_ADDR="192.168.12.88"
DGC_HOST_ADDR="192.168.12.88"
