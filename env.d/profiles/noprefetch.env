# Profile: disable SnicGCRDMAPrefetchEnabled.
# Appended after HOST_FLAGS / runner-dgc append, so last-wins disables prefetch
# on host JVM cmdlines. Used to isolate whether RDMA prefetch is the source of
# the GC(1) SIGSEGV in dgc-rdma update-refs.
COMMON_FLAGS="${COMMON_FLAGS} -XX:-SnicGCRDMAPrefetchEnabled"
